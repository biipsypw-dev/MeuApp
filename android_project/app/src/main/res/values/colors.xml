<?xml version="1.0" encoding="utf-8"?>
<!--=================================================
    RECURSOS DE COR — colors.xml
    Paleta centralizada do aplicativo.
    Altere aqui para mudar as cores em todo o app.

    Paleta atual: Azul escuro / Índigo
=================================================-->
<resources>

    <!--── SEÇÃO SUPERIOR (Relógio) ─────────────────
        Fundo da metade de cima da tela
    ─────────────────────────────────────────────-->
    <color name="section_top">#1A237E</color>       <!-- Azul índigo escuro -->

    <!--── SEÇÃO INFERIOR (Status + Menu) ───────────
        Fundo da metade de baixo da tela
        Ligeiramente mais claro que o topo
    ─────────────────────────────────────────────-->
    <color name="section_bottom">#283593</color>    <!-- Azul índigo médio -->

    <!--── MENU LATERAL (Drawer) ────────────────────
        Fundo da tela do menu sobreposto
        Mais escuro para criar hierarquia visual
    ─────────────────────────────────────────────-->
    <color name="drawer_bg">#0D1B6B</color>         <!-- Azul índigo muito escuro -->

    <!--── TEXTOS ───────────────────────────────────-->
    <color name="text_light">#FFFFFF</color>         <!-- Branco puro — títulos e valores -->
    <color name="text_light_dim">#90CAF9</color>     <!-- Azul claro — textos secundários -->

    <!--── DIVISOR ──────────────────────────────────-->
    <color name="divider">#3949AB</color>            <!-- Linha separadora no menu -->

</resources>
